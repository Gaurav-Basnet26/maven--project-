pipeline {
    agent any

    stages {
        stage('Compile') {
            steps {
                echo 'Compile code'
            }
        }

        stage('UnitTest') {
            steps {
                echo 'Unit test'
            }
        }

        stage('SecurityScan') {
            steps {
                echo 'Scan vulnerability'
            }
        }

        stage('QualityGate') {
            steps {
                echo 'QGate'
            }
        }

        stage('Create') {
            steps {
                echo 'Creating docker image'
            }
        }

        stage('PushImage') {
            steps {
                echo 'Push image to registry'
            }
        }
    }
}

